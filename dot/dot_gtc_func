#!bin/bash

gclone() {
    c_pwd=`pwd`
    cd $HOME/Devel
    git clone git@github.com:k0pernicus/$1.git
    cd $c_pwd
}

update_hugo() {
    c_pwd=`pwd`
    cd $HOME/Devel
    [[ -d hugo ]] || git clone https://github.com/gohugoio/hugo.git && \
    cd hugo && \
    git pull && \
    go install --tags extended
    cd $c_pwd
}

if [[ "$OSTYPE" == "linux-gnu"* ]]; then
    update_system() {
        sudo nixos-rebuild switch --flake ~/Devel/dotfiles/config/nixos-config/#phobos
    }

elif [[ "$OSTYPE" == "darwin"* ]]; then
    update_system() {
        sudo darwin-rebuild switch --flake ~/System/nix-darwin-config 
    }

    update_nix() {
        c_pwd=`pwd`
        cd ~/System/nix-darwin-config
        sudo nix flake update
        cd $c_pwd
    }
fi
